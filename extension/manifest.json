{
  "manifest_version": 3,
  "name": "YouTube Transcript Sidebar",
  "version": "1.0",
  "description": "AI-powered YouTube transcript, summary, screenshots, and comments",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "http://localhost:5000/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
